---
import '../../../styles/global.css';
import '../../../styles/index.css';

import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
const lang = 'en';
const t = useTranslations(lang);

import Layout from '../../../layouts/Layout.astro';
import Prose from '../../../components/Global/Prose.astro';
import FooterSection from '../../../components/Footer/FooterSection.astro';
import NavIsland from '../../../components/NavIsland/NavIsland.astro';

// 1. Import utilities from: 
// 'astro:content' to get collections and render content
// 'astro:assets' for Astro to optimize images
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

// 2. Gets each selected file from the collection asynchronously
export async function getStaticPaths() {
    const posts = await getCollection('projects');
    
    return posts
        .filter(post => post.id.startsWith('en/')) 
        .map(post => ({
            params: { slug: post.id.replace('en/', '') },
            props: { post }
        }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { tags } = post.data;
---

<Layout>
    <main class="w-full max-w-[1200px] px-12 pb-16 tracking-wide transition-all max-sm:px-4">
        <!-- Hero aricle section -->
        <section class="mt-16 sm:mt-24 sm:font-light lg:mt-32">
            <div class="space-x-1 text-sm text-zinc-400 sm:text-lg">
                <span>{post.data.pubDate}</span>
                <span>•</span>
                <span>{post.data.readTime} read</span>
            </div>
            <h1 class="font-heading mt-4 text-[clamp(1.8rem,5vw,2.5rem)] font-bold leading-tight sm:mt-6 md:leading-[1.1]">{post.data.title}</h1>
            <h3 class="mt-4 text-zinc-400 max-sm:text-sm">{post.data.description}</h3>
            <ul class="mt-8 flex flex-wrap gap-2">
                {tags.map(tag => (
                        <li class="border border-zinc-500 rounded bg-zinc-900 group-hover:border-purple-400 active:border-purple-400 px-2 py-1 font-mono text-xs tracking-tight text-zinc-200 font-bold">
                            {tag}
                        </li>
                    ))
                }
            </ul>
        </section>
        
        <!-- Hero image -->
        <div class="h-fit w-fit bg-cover bg-center ambient-mode rounded-lg mt-8 sm:mt-12">
            <Image src={post.data.banner} alt={post.data.title} class="object-cover object-center h-[inherit] max-h-[inherit] rounded-[inherit] aspect-[1.5] w-full xs:aspect-[2]"/>
        </div>

        <!-- Article section -->
        <section class="mt-8 flex w-full gap-16 sm:mt-16">
            <Prose>
                <!-- Mobile links -->
                <div class="mt-10 md:hidden rounded-lg border border-zinc-800">
                    <ul class="list-none">
                        <li>
                            <a class="flex flex-row gap-3 items-center hover:text-zinc-400 transition-colors" href={post.data.sourceCode} target="_blank" rel="noopener noreferrer">
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-5 rounded group-focus-within:outline outline-offset-4 outline-purple-400">
                                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" color="currentColor">
                                        <path d="M10 20.568c-3.429 1.157-6.286 0-8-3.568"></path>
                                        <path d="M10 22v-3.242c0-.598.184-1.118.48-1.588c.204-.322.064-.78-.303-.88C7.134 15.452 5 14.107 5 9.645c0-1.16.38-2.25 1.048-3.2c.166-.236.25-.354.27-.46c.02-.108-.015-.247-.085-.527c-.283-1.136-.264-2.343.16-3.43c0 0 .877-.287 2.874.96c.456.285.684.428.885.46s.469-.035 1.005-.169A9.5 9.5 0 0 1 13.5 3a9.6 9.6 0 0 1 2.343.28c.536.134.805.2 1.006.169c.2-.032.428-.175.884-.46c1.997-1.247 2.874-.96 2.874-.96c.424 1.087.443 2.294.16 3.43c-.07.28-.104.42-.084.526s.103.225.269.461c.668.95 1.048 2.04 1.048 3.2c0 4.462-2.134 5.807-5.177 6.643c-.367.101-.507.559-.303.88c.296.47.48.99.48 1.589V22"></path>
                                    </g>
                                </svg>
                                {t('aside.source.code')}
                            </a>
                        </li>
                        
                        <li>
                            <a class="flex flex-row gap-3 items-center hover:text-zinc-400 transition-colors" href="">
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-5 rounded group-focus-within:outline outline-offset-4 outline-purple-400">
                                    <path d="M0 0h24v24H0z" fill="none" />
                                    <path fill="currentColor" d="M21.409 9.353a2.998 2.998 0 0 1 0 5.294L8.597 21.614C6.534 22.737 4 21.277 4 18.968V5.033c0-2.31 2.534-3.769 4.597-2.648z" />
                                </svg>
                                {t('aside.demo')}
                            </a>
                        </li>
                    </ul>
                </div>

                <Content />
            </Prose>
            
            <!-- Article headers navigation bar -->
            <aside class="mt-13 w-60 shrink-0 space-y-8 max-lg:hidden">
                <!-- Post navigation -->
                <div class="font-secondary sticky top-32">
                    <div class="mb-5">
                        <p class="font-display text-lg font-semibold text-zinc-200">{t('aside.on.this.page')}</p>
                        <ul class="mt-2 space-y-1.5 text-[0.9rem] text-zinc-400/90 scrollbar-color max-h-[480px] overflow-y-scroll">
                            {headings
                                .filter(h => h.depth <= 4)
                                .map(heading => (
                                    <li>
                                        <a class="aside-links hover:text-zinc-400 transition-colors" href={`#${heading.slug}`}>
                                            {heading.text}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <!-- Divider -->
                    <div class="h-[1px] w-full bg-zinc-800"></div>

                    <!-- Project post links -->
                    <div class="mt-5">
                        <p class="font-display text-lg font-semibold text-zinc-200">{t('aside.links')}</p>
                        <ul class="mt-2 space-y-3 text-[0.9rem] text-zinc-500 scrollbar-color max-h-[480px] overflow-y-scroll">   
                            <!-- Source code -->
                            <li>
                                <a class="custom-link flex flex-row gap-3 items-center hover:text-zinc-400 transition-colors" href={post.data.sourceCode} target="_blank" rel="noopener noreferrer">
                                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-5 rounded group-focus-within:outline outline-offset-4 outline-purple-400">
                                        <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" color="currentColor">
                                            <path d="M10 20.568c-3.429 1.157-6.286 0-8-3.568"></path>
                                            <path d="M10 22v-3.242c0-.598.184-1.118.48-1.588c.204-.322.064-.78-.303-.88C7.134 15.452 5 14.107 5 9.645c0-1.16.38-2.25 1.048-3.2c.166-.236.25-.354.27-.46c.02-.108-.015-.247-.085-.527c-.283-1.136-.264-2.343.16-3.43c0 0 .877-.287 2.874.96c.456.285.684.428.885.46s.469-.035 1.005-.169A9.5 9.5 0 0 1 13.5 3a9.6 9.6 0 0 1 2.343.28c.536.134.805.2 1.006.169c.2-.032.428-.175.884-.46c1.997-1.247 2.874-.96 2.874-.96c.424 1.087.443 2.294.16 3.43c-.07.28-.104.42-.084.526s.103.225.269.461c.668.95 1.048 2.04 1.048 3.2c0 4.462-2.134 5.807-5.177 6.643c-.367.101-.507.559-.303.88c.296.47.48.99.48 1.589V22"></path>
                                        </g>
                                    </svg>
                                    <p>-</p>
                                    {t('aside.source.code')}
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </aside>
        </section>
        
        <!-- Explore more button -->
        <section class="group w-fit mt-16">
            <a class="custom-link group-hover:font-bold underline-offset-5 no-underline text-purple-400" href=`/${lang}/projects`>
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="mr-2 inline-block size-4 -scale-x-100">
                    <path fill="currentColor" d="M16.175 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.712t.3-.713z"></path>
                </svg>
                {t('projects.slug.explore.more')}
            </a>
        </section>
    </main>
    <FooterSection />
    <NavIsland />
</Layout>