---
const { name, url } = Astro.props;
---

<div class="key-position" data-astro-cid-socials>
    <a class="key" aria-label={name} data-key={name} target="_blank" rel="noopener noreferrer" href={url} data-astro-cid-socials>
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" data-astro-cid-socials="true">
            <slot />
        </svg>
    </a>
</div>