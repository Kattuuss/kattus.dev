---
import { Icon } from "astro-icon/components";

interface LogoDictionary {
    [key: string]: string;
}

const logos: LogoDictionary = {
    java: "logos:java",
    oracle: "devicon:sqldeveloper",
    spring: "devicon:spring",
    springboot: "simple-icons:springboot",
    astro: "vscode-icons:file-type-astro",
    tailwind: "devicon:tailwindcss",
    gsap: "simple-icons:gsap",
    lua: "devicon:lua",
    typescript: "devicon:typescript",
    linux: "devicon:linux",
    arch: "devicon:archlinux",
    ubuntu: "logos:ubuntu",
    windows: "devicon:windows11",
    html: "devicon:html5",
    bash: "devicon-plain:bash"
};
---

<div class="grid grid-rows-2 rounded-2xl w-full border-2 border-white p-5 gap-3 place-items-center">
    <div class="rounded-2xl space-y-2">
        <p class="text-xl text-white">Front</p>
        <Icon name={logos.astro} class="text-5xl border-2 border-slate-300 rounded-2xl" />
    </div>
    <div class="rounded-2xl space-y-2">
        <p class="text-xl text-white">Back</p>
        <Icon name={logos.tailwind} class="text-5xl border-2 border-slate-300 rounded-2xl" />
    </div>
</div>