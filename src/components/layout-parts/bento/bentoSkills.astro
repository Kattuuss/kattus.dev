---
import { Icon } from "astro-icon/components";

interface LogoDictionary {
    [key: string]: string;
}

const logos: LogoDictionary = {
    java: "logos:java",
    oracle: "devicon:sqldeveloper",
    spring: "devicon:spring",
    springboot: "simple-icons:springboot",
    astro: "vscode-icons:file-type-astro",
    tailwind: "devicon:tailwindcss",
    gsap: "simple-icons:gsap",
    lua: "devicon:lua",
    typescript: "devicon:typescript",
    linux: "devicon:linux",
    arch: "devicon:archlinux",
    ubuntu: "logos:ubuntu",
    windows: "devicon:windows11",
    html: "devicon:html5",
    bash: "devicon-plain:bash"
};
---

<div class="group relative grid grid-rows-2 rounded-2xl w-full border-2 border-white p-5 gap-2 place-items-center">
    <div class="space-y-2 border-2 border-slate-300 rounded-2xl p-3">
        <p class="text-xl text-white select-none underline text-center">Front</p>
        <Icon name={logos.astro} class="text-5xl" />
    </div>
    <div class="space-y-2 border-2 border-slate-300 rounded-2xl p-3">
        <p class="text-xl text-white select-none underline text-center">Back</p>
        <Icon name={logos.tailwind} class="text-5xl" />
    </div>

    <div class="absolute top-3 right-3 opacity-0 transition-opacity duration-300 group-hover:opacity-100 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75 3 12m0 0 3.75-3.75M3 12h18" />
        </svg>
    </div>
</div>