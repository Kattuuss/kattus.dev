---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import MoreBtn from "../Global/MoreBtn.astro";
import ReturnBtn from "../Global/ReturnBtn.astro";
import ProjectCard from "./ProjectCard.astro";

const currentPath = Astro.url.pathname;

import linkWeaverImg from '../../assets/projects/linkweaver/linkweaver.jpg';
import muuMeImg from '../../assets/projects/muume/muume.jpg';

interface Props {
    limit?: number;
}

const { limit } = Astro.props;

const projects = [
    {
        url: `/${lang}/projects/linkweaver`,
        img: linkWeaverImg,
        alt: t('projects.linkweaver.card.alt'),
        year: "2026",
        name: "LinkWeaver",
        description: t('projects.linkweaver.card.description')
    },
    {
        url: `/${lang}/projects/muume`,
        img: muuMeImg,
        alt: t('projects.muume.card.alt'),
        year: "2026",
        name: "MuuMe",
        description: t('projects.muume.card.description')
    },
];

const displayedProjects = limit ? projects.slice(0, limit) : projects;
---

<!-- Projects Section -->
<section id="projects" class="mt-40 scroll-mt-16">
    <div class="items-center justify-between gap-4 lg:flex">
        <div class="space-y-6 sm:space-y-8">
            <!-- Section tag -->
            <div class="flex w-fit items-center gap-2 rounded-full bg-purple-950/55 px-4 py-2 text-purple-300">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                    <path d="M0 0h24v24H0z" fill="none" />
                    <path fill="currentColor" d="M12.876.64V.639l8.25 4.763c.541.313.875.89.875 1.515v9.525a1.75 1.75 0 0 1-.875 1.516l-8.25 4.762a1.75 1.75 0 0 1-1.75 0l-8.25-4.763a1.75 1.75 0 0 1-.875-1.515V6.917c0-.625.334-1.202.875-1.515L11.126.64a1.75 1.75 0 0 1 1.75 0m-1 1.298L4.251 6.34l7.75 4.474l7.75-4.474l-7.625-4.402a.25.25 0 0 0-.25 0m.875 19.123l7.625-4.402a.25.25 0 0 0 .125-.216V7.639l-7.75 4.474ZM3.501 7.64v8.803c0 .09.048.172.125.216l7.625 4.402v-8.947Z" />
                </svg>
                <h2 class="text-sm font-medium tracking-wide max-sm:text-xs">{t('projects.section.tag')}</h2>
            </div>

            <!-- Section intro CHANGE!!! -->
            <h3 class="font-heading font-semibold leading-none text-[clamp(2rem,7vw,3rem)]">
                {t('projects.section.title.part1')}
                <br>
                {t('projects.section.title.part2')}
            </h3>
            <p class="text-zinc-400 max-md:text-sm">
                {t('projects.section.description.part1')}
                <br class="max-md:hidden">
                {t('projects.section.description.part2')}
            </p>
        </div>

        { currentPath === `/${lang}/projects` || currentPath === `/${lang}/projects/` ? 
            <ReturnBtn msg={t('global.return.button')} /> : 
            <MoreBtn msg={t('projects.view.more.button')} url={`/${lang}/projects/`} /> 
        }
    </div>

    <!-- Higlighted projects -->
    <div class="mt-12 grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
        {displayedProjects.map((p) => (
            <ProjectCard 
                url={p.url}
                img={p.img}
                alt={p.alt}
                year={p.year}
                name={p.name}
                description={p.description}
            />
        ))}
    </div>
</section>