---
import MoreBtn from "../MoreBtn.astro";
import ReturnBtn from "../ReturnBtn.astro";
import ProjectCard from "./ProjectCard.astro";

const currentPath = Astro.url.pathname;
---

<!-- Projects Section -->
<section id="projects" class="mt-40 scroll-mt-16">
    <div class="items-center justify-between gap-4 lg:flex">
        <div class="space-y-6 sm:space-y-8">
            <!-- Section tag -->
            <div class="flex w-fit items-center gap-2 rounded-full bg-purple-950/55 px-4 py-2 text-purple-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                    <path d="M0 0h24v24H0z" fill="none" />
                    <path fill="currentColor" d="M12.876.64V.639l8.25 4.763c.541.313.875.89.875 1.515v9.525a1.75 1.75 0 0 1-.875 1.516l-8.25 4.762a1.75 1.75 0 0 1-1.75 0l-8.25-4.763a1.75 1.75 0 0 1-.875-1.515V6.917c0-.625.334-1.202.875-1.515L11.126.64a1.75 1.75 0 0 1 1.75 0m-1 1.298L4.251 6.34l7.75 4.474l7.75-4.474l-7.625-4.402a.25.25 0 0 0-.25 0m.875 19.123l7.625-4.402a.25.25 0 0 0 .125-.216V7.639l-7.75 4.474ZM3.501 7.64v8.803c0 .09.048.172.125.216l7.625 4.402v-8.947Z" />
                </svg>
                <h2 class="text-sm font-medium tracking-wide max-sm:text-xs">Projects</h2>
            </div>

            <!-- Section intro CHANGE!!! -->
            <h3 data-astro-transition-scope="astro-zl27eeyh-4" class="font-heading font-semibold leading-none text-[clamp(2rem,7vw,3rem)]">
                Milestones in the
                <br>
                learning journey
            </h3>
            <p class="text-zinc-400 max-md:text-sm" data-astro-transition-scope="astro-6kb5rfva-5">
                Each project marks a step forward, showcasing my growth and journey as a developer.
                <br class="max-md:hidden">
                Explore how I’ve tackled challenges and built solutions along the way.
            </p>
        </div>

        { currentPath === "/projects" || currentPath === "/projects/" ? <ReturnBtn msg="Return home" url="/" /> : <MoreBtn msg="View all projects" url="/projects" /> }
    </div>

    <!-- Higlighted projects -->
    <div class="mt-12 grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
        <!-- web-krawler -->
        <ProjectCard 
            url="projects/web-krawler"
            img="public/web-krawler.svg"
            alt="Web-Krawler: A Simple Web Crawler for extracting hyperlinks."
            year="2026"
            name="web-krawler"
            description="A Java application that allows users to find and store inside a JSON file hyperlinks inside a given webpage."
        />

        <!-- muume -->
        <ProjectCard 
            url="projects/muume"
            img="public/muume.svg"
            alt="MuuMe: A Web Application to privately chat with your people."
            year="2026"
            name="muume"
            description="Designed for people who wants a privacy-first messaging web application. Soon on mobile!."
        />
    </div>
</section>