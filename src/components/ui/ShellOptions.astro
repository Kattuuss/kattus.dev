---
import { Icon } from "astro-icon/components";
---

<div>
    <div class="flex flex-col gap-3 rounded-full bg-[#141b18] w-8">
        <!-- Sidebar to left/right toggle -->
        <button class="flex justify-center items-center rounded-full bg-purple-400 text-2xl text-[#dde8e2] w-8 h-8">
            <!-- Use right side -->
            <Icon name="hugeicons:sidebar-right" class="rounded-xl text-white text-xl" />
            <!-- Use left side -->
            <!-- <Icon name="hugeicons:sidebar-left" class="rounded-xl text-white text-xl" /> -->
        </button>
        
        <!-- Dark/Light mode toggle -->
        <button class="flex justify-center items-center rounded-full bg-purple-400 text-2xl text-[#dde8e2] w-8 h-8">
            <!-- Dark mode -->
            <Icon name="solar:moon-bold" class="rounded-xl text-white text-xl" />
            <!-- Light mode -->
            <!-- <Icon name="solar:sun-bold" class="rounded-xl text-white w-8 h-8" /> -->
        </button>
    </div>
</div>