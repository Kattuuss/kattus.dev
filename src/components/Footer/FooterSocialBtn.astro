---
const { name, url } = Astro.props;
---

<a class="custom-link group" aria-label={name} href={url} target="_blank" rel="noopener noreferrer">
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-5 rounded group-focus-within:outline outline-offset-4 outline-purple-400">
        <slot />
    </svg> 
</a> 