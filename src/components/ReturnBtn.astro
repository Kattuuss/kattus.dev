---
const { msg } = Astro.props;
---

<a class="custom-button group max-lg:hidden rounded-3xl" href="/">
    <div class="pt-3 pb-3 pl-8 pr-8 flex justify-center items-center gap-3 border rounded-[inherit] border-white transition-all duration-300 group-hover:bg-purple-950/55 group-hover:border-purple-300 group-focus-within:bg-purple-950/55 group-focus-within:border-purple-300">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4 rotate-180" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M16.1716 10.9999L10.8076 5.63589L12.2218 4.22168L20 11.9999L12.2218 19.778L10.8076 18.3638L16.1716 12.9999H4V10.9999H16.1716Z"></path>
        </svg>
        <span>{msg}</span>
    </div>
</a>