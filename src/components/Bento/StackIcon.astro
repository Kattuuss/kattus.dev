---
const { name, icon, color } = Astro.props;
---

<div class={`flex flex-col items-center gap-2 ${color}`}>
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-12 md:max-lg:size-8">
        <Fragment set:html={icon} />
    </svg>
    <p>{name}</p>
</div>