import StackIcon from './StackIcon.astro';
import profilePictureImg from '../../assets/random-pfp.png';
import { Image } from 'astro:assets';
---

<!-- Bento Section -->
<section id="bento" class="auto-rows-fr grid-cols-36 gap-4 flex-col max-lg:grid-cols-6 max-md:flex max-md:gap-4 md:grid">
    <!-- Projects call to action -->
    <div class="card group rounded-3xl col-start-1 col-end-15 row-start-1 row-end-6 max-lg:col-start-4 max-lg:col-end-7 max-lg:row-start-3 max-lg:row-end-4">
        <div class="card-content md:absolute border-[#1f2b3a] max-md:border">
            <a href="#projects" class="custom-link flex size-full items-center justify-between rounded-3xl p-6">
                <p class="discover-more relative font-medium after:absolute after:left-0 after:top-1/2 after:w-0 after:content-[''] after:bg-primary-gradient after:mt-3 after:h-0.5 after:transition-all after:duration-400 group-hover:after:w-full">
                    Check this projects
                </p>
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="size-6 transition-all duration-300 group-hover:rotate-90">
                    <path fill="currentColor" d="M16.175 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.712t.3-.713z"></path>
                </svg>
            </a>
        </div>
    </div>
    
    <!-- Stack -->
    <div class="card group rounded-3xl col-start-1 col-end-15 row-start-6 row-end-25 max-lg:col-start-4 max-lg:col-end-7 max-lg:row-start-6 max-lg:row-end-9">
        <div class="card-content md:absolute border-[#1f2b3a] max-md:border">
            <div class="flex h-full flex-col gap-5 px-5 pb-6 pt-4 max-md:gap-8">
                <!-- Label -->
                <div class="z-10 flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950 shrink-0 py-2 pl-3 pr-4 w-fit">
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 256 256" class="size-4">
                        <g fill="currentColor">
                            <path d="m220 169.09l-92 53.65l-92-53.65a8 8 0 0 0-8 13.82l96 56a8 8 0 0 0 8.06 0l96-56a8 8 0 1 0-8.06-13.82"></path>
                            <path d="m220 121.09l-92 53.65l-92-53.65a8 8 0 0 0-8 13.82l96 56a8 8 0 0 0 8.06 0l96-56a8 8 0 1 0-8.06-13.82"></path>
                            <path d="m28 86.91l96 56a8 8 0 0 0 8.06 0l96-56a8 8 0 0 0 0-13.82l-96-56a8 8 0 0 0-8.06 0l-96 56a8 8 0 0 0 0 13.82"></path>
                        </g>
                    </svg>
                    <h3 class="text-sm text-zinc-200 select-none">Tech stack</h3>
                </div>

                <!-- Icons belt / conveyor -->
                <div class="flex-grow place-content-center">
                    <div class="relative flex w-full flex-col items-center justify-center overflow-hidden md:shadow-xl">
                        <!-- Icons -->
                        <div class="group flex overflow-hidden p-2 [--gap:2rem] gap-(--gap) flex-row [--duration:20s]">
                            {Array.from({ length: 4 }).map(() => (
                                <div class="flex shrink-0 justify-around gap-(--gap) motion-reduce:animate-none animate-marquee flex-row">
                                    {technologies.map(tech => (
                                        <StackIcon {...tech} />
                                    ))}
                                </div>
                            ))}
                        </div>

                        <!-- Blurs -->
                        <div class="pointer-events-none absolute inset-y-0 left-0 w-1/3 bg-linear-to-r from-(--card-background)"></div>
                        <div class="pointer-events-none absolute inset-y-0 right-0 w-1/3 bg-linear-to-l from-(--card-background)"></div>
                    </div>
                </div>

                <!-- Description CHANGE!!! -->
                <div class="space-y-2">
                    <p class="text-lg">Tech stacks I'm familiar with</p>
                    <p class="text-sm text-slate-400">Primarily focused on the Java ecosystem, but always eager to explore and learn new technologies.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Studies -->
    <!-- <div class="card group rounded-3xl col-start-15 col-end-37 row-start-6 row-end-20 max-lg:col-start-4 max-lg:col-end-7 max-lg:row-start-6 max-lg:row-end-9">
        <div class="card-content md:absolute border-[#1f2b3a] max-md:border">
            <div class="flex h-full flex-col gap-5 px-5 pb-6 pt-4 max-md:gap-8">
                Label
                <div class="z-10 flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950 shrink-0 py-2 pl-3 pr-4 w-fit">
