---
import '../styles/global.css';

const pageTitle = "Alex | Portfolio"
---

<!doctype html>
<html class="dark" lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<script defer src="https://cloud.umami.is/script.js" data-website-id="0756346c-c90a-4451-a31d-c99a5391b8f2"></script>
	</head>
	<body class="flex min-h-dvh flex-col items-center bg-zinc-950 text-white">
		<div class="astro-loading-indicator" aria-hidden="true"></div>
		<slot />
    </body>
</html>

<script>
	const progressBar = document.querySelector('.astro-loading-indicator') as HTMLElement;

	window.addEventListener('scroll', () => {
		if (progressBar) {
		// Calculates scroll percentage
		const totalScroll = document.documentElement.scrollTop;
		const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
		const scrollPercentage = totalScroll / windowHeight;

		// Applies the value to the CSS variable
		progressBar.style.setProperty('--progress', scrollPercentage.toString());
		}
	});
</script>